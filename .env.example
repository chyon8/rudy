# 이 파일은 커밋됨 (템플릿). 실제 값은 .env에.

# --- AI (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini            # ingestion 분석 (고volume)
OPENAI_MODEL_REASON=gpt-4o-mini     # 일 1회 문구 생성. 톤 품질 필요 시 gpt-4o로 상향
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024           # text-embedding-3-* 는 dimensions 파라미터로 1024 출력 → VECTOR(1024) 유지

# --- Infra ---
DATABASE_URL=postgres://rudy:rudy@localhost:5432/rudy
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=
AUTH_DEV_MODE=true

# --- Storage ---
STORAGE_DRIVER=local                # local | s3
# S3_BUCKET=
# S3_REGION=
# S3_ENDPOINT=

# --- M4 이후 ---
APPLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
EXPO_ACCESS_TOKEN=
